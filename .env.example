DB_HOST=localhost
DB_PORT=5432
DB_NAME=incentivemgmt
DB_USER=postgres
DB_PASSWORD=postgres
JWT_SECRET=your_jwt_secret_here
PORT=5000

# System-to-system authentication
SYSTEM_JWT_SECRET=your-system-jwt-secret-here

# SFTP (Life Asia AS400 file polling)
SFTP_HOST=sftp.yourserver.com
SFTP_PORT=22
SFTP_USERNAME=incentive_sys
SFTP_PASSWORD=***
SFTP_BASE_PATH=/inbound/lifeasia

# Hierarchy API
HIERARCHY_API_BASE=https://internal-hierarchy/api
HIERARCHY_API_CLIENT_ID=incentive_sys
HIERARCHY_API_CLIENT_SECRET=***

# Penta API
PENTA_API_BASE=https://kgils-penta/api
PENTA_CLIENT_ID=incentive_sys
PENTA_CLIENT_SECRET=***

# Integration Export
SAP_COMPANY_CODE=1000
ORACLE_OPERATING_UNIT=Vision Operations
